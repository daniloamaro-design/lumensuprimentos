async function loadFreteirosCache() {
  freteirosCache = {};
  const snap = await db.collection(FRETEIROS_COL).get();
  snap.docs.forEach(d => { freteirosCache[d.id] = { id: d.id, ...d.data() }; });
}

function populateFreteirosSelects() {
  const ativos = Object.values(freteirosCache).filter(f => f.status === 'ativo');
  ['nf-freteiro','filter-freteiro','fin-freteiro'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const current = el.value;
    const isFilter = id.startsWith('filter') || id.startsWith('fin');
    el.innerHTML = isFilter ? '<option value="">Todos</option>' : '<option value="">Selecione...</option>';
    ativos.forEach(f => {
      const o = document.createElement('option');
      o.value = f.id; o.textContent = f.nome;
      el.appendChild(o);
    });
    if (current) el.value = current;
  });
}

async function loadFreteiros() {
  const tbody = document.getElementById('freteiros-tbody');
  tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:24px;"><div class="loading-state"><div class="spinner spinner-dark"></div></div></td></tr>';

  await loadFreteirosCache();
  const freteiros = Object.values(freteirosCache).sort((a,b) => a.nome.localeCompare(b.nome));

  if (freteiros.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">🚛</div><div class="empty-title">Nenhum freteiro cadastrado</div></div></td></tr>';
    return;
  }

  // Calcula totais por freteiro
  const fretesSnap = await db.collection(FRETES_COL).get();
  const totais = {};
  fretesSnap.docs.forEach(d => {
    const f = d.data();
    if (!totais[f.freteiro_id]) totais[f.freteiro_id] = { count: 0, pago: 0 };
    totais[f.freteiro_id].count++;
    totais[f.freteiro_id].pago += parseFloat(f.valor_pago) || 0;
  });

  tbody.innerHTML = freteiros.map(f => {
    const t = totais[f.id] || { count: 0, pago: 0 };
    return `<tr>
      <td><strong>${f.nome}</strong></td>
      <td class="text-muted">${f.cpf || '—'}</td>
      <td>${f.telefone || '—'}</td>
      <td>
        ${f.pix_chave ? `<span class="pix-badge">⚡ ${f.pix_tipo?.toUpperCase()||'PIX'}: ${f.pix_chave}</span>` : '<span class="text-muted">—</span>'}
      </td>
      <td style="text-align:center;">${t.count}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;color:var(--ok);">R$ ${t.pago.toFixed(2)}</td>
      <td><span class="badge ${f.status==='ativo'?'badge-ok':'badge-gray'}">${f.status==='ativo'?'Ativo':'Inativo'}</span></td>
      <td style="display:flex;gap:6px;">
        <button class="btn btn-secondary btn-xs" onclick="showFreteiro('${f.id}')">Ver</button>
        <button class="btn btn-outline btn-xs" onclick="editFreteiro('${f.id}')">Editar</button>
      </td>
    </tr>`;
  }).join('');

  populateFreteirosSelects();
}

function openModalFreteiro() {
  document.getElementById('mf-id').value = '';
  document.getElementById('modal-freteiro-title').textContent = 'Novo Freteiro';
  ['mf-nome','mf-cpf','mf-telefone','mf-pix-chave','mf-obs'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('mf-pix-tipo').value = 'cpf';
  document.getElementById('mf-status').value   = 'ativo';
  openModal('modal-freteiro');
}

function editFreteiro(id) {
  const f = freteirosCache[id];
  if (!f) return;
  document.getElementById('mf-id').value        = id;
  document.getElementById('modal-freteiro-title').textContent = 'Editar Freteiro';
  document.getElementById('mf-nome').value      = f.nome || '';
  document.getElementById('mf-cpf').value       = f.cpf || '';
  document.getElementById('mf-telefone').value  = f.telefone || '';
  document.getElementById('mf-pix-tipo').value  = f.pix_tipo || 'cpf';
  document.getElementById('mf-pix-chave').value = f.pix_chave || '';
  document.getElementById('mf-status').value    = f.status || 'ativo';
  document.getElementById('mf-obs').value       = f.obs || '';
  openModal('modal-freteiro');
}

async function salvarFreteiro() {
  const id       = document.getElementById('mf-id').value;
  const nome     = v('mf-nome');
  const cpf      = v('mf-cpf');
  const telefone = v('mf-telefone');

  if (!nome) { showToast('Nome é obrigatório!'); return; }
  if (!cpf)  { showToast('CPF é obrigatório!'); return; }
  if (!telefone) { showToast('Telefone é obrigatório!'); return; }

  setBtnLoading('btn-salvar-freteiro', true);

  const data = {
    nome, cpf, telefone,
    pix_tipo:  v('mf-pix-tipo'),
    pix_chave: v('mf-pix-chave'),
    status:    v('mf-status'),
    obs:       v('mf-obs'),
    updatedAt: firebase.firestore.FieldValue.serverTimestamp()
  };

  try {
    if (id) {
      await db.collection(FRETEIROS_COL).doc(id).update(data);
      showToast('✅ Freteiro atualizado!');
    } else {
      data.createdAt = firebase.firestore.FieldValue.serverTimestamp();
      data.createdBy = currentUserData.name;
      await db.collection(FRETEIROS_COL).add(data);
      showToast('✅ Freteiro cadastrado!');
    }
    closeModal('modal-freteiro');
    await loadFreteiros();
  } catch(e) {
    showToast('Erro: ' + e.message);
  }
  setBtnLoading('btn-salvar-freteiro', false);
}

async function showFreteiro(id) {
  const f = freteirosCache[id];
  if (!f) return;
  document.getElementById('modal-fd-title').textContent = f.nome;

  // Carrega fretes deste freteiro
  const snap = await db.collection(FRETES_COL).where('freteiro_id','==',id).orderBy('data','desc').get();
  const fretes = snap.docs.map(d => ({ id: d.id, ...d.data() }));

  let totalPago = 0, totalValor = 0;
  fretes.forEach(f => {
    totalValor += parseFloat(f.valor) || 0;
    totalPago  += parseFloat(f.valor_pago) || 0;
  });

  const fretesHTML = fretes.length === 0
    ? '<div class="empty-state" style="padding:24px;"><div class="empty-icon">📋</div><div class="empty-title">Nenhum frete registrado</div></div>'
    : fretes.map(fr => `
      <div class="timeline-item">
        <div class="timeline-dot" style="background:${statusColor(fr.status)};"></div>
        <div class="timeline-content">
          <div class="timeline-title">${fr.code} — ${fr.origem} → ${fr.destino}</div>
          <div class="timeline-sub">${formatDate(fr.createdAt)} · R$ ${parseFloat(fr.valor).toFixed(2)} · ${statusLabel(fr.status)}</div>
        </div>
      </div>`).join('');

  document.getElementById('modal-fd-body').innerHTML = `
    <div class="grid-2 mb-16">
      <div class="stat-card ok"><div class="stat-label">Total de Fretes</div><div class="stat-value">${fretes.length}</div></div>
      <div class="stat-card purple"><div class="stat-label">Total Pago</div><div class="stat-value money">R$ ${totalPago.toFixed(2)}</div></div>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;">
      ${f.cpf ? `<span class="badge badge-gray">CPF: ${f.cpf}</span>` : ''}
      ${f.telefone ? `<span class="badge badge-gray">📞 ${f.telefone}</span>` : ''}
      ${f.pix_chave ? `<span class="pix-badge">⚡ ${f.pix_tipo?.toUpperCase()||'PIX'}: ${f.pix_chave}</span>` : ''}
      <span class="badge ${f.status==='ativo'?'badge-ok':'badge-gray'}">${f.status==='ativo'?'Ativo':'Inativo'}</span>
    </div>
    ${f.obs ? `<div class="info-box mb-16">${f.obs}</div>` : ''}
    <div class="card-header-title" style="margin-bottom:12px;">Histórico de Fretes</div>
    <div class="timeline">${fretesHTML}</div>`;

  openModal('modal-freteiro-detail');
}

