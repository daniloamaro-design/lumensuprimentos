async function loadDashboard() {
  const now = new Date();
  const mesAtual = now.toISOString().slice(0,7);
  const snap = await db.collection(FRETES_COL).orderBy('createdAt','desc').get();
  const todos = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  const doMes = todos.filter(f => f.data?.startsWith(mesAtual));

  const andamento = todos.filter(f => ['solicitado','separado','transporte'].includes(f.status)).length;
  const entregues = doMes.filter(f => f.status === 'entregue').length;
  const pendentes = todos.filter(f => f.status_pag !== 'pago' && f.status !== 'cancelado').length;
  const totalPago = doMes.reduce((a,f) => a + (parseFloat(f.valor_pago)||0), 0);
  const totalAPagar = todos
    .filter(f => f.status_pag !== 'pago' && f.status !== 'cancelado')
    .reduce((a,f) => a + ((parseFloat(f.valor)||0)-(parseFloat(f.valor_pago)||0)), 0);

  document.getElementById('s-total').textContent     = doMes.length;
  document.getElementById('s-andamento').textContent = andamento;
  document.getElementById('s-entregues').textContent = entregues;
  document.getElementById('s-pendentes').textContent = pendentes;
  document.getElementById('s-pago').textContent      = `R$ ${totalPago.toFixed(2)}`;
  document.getElementById('s-apagar').textContent    = `R$ ${totalAPagar.toFixed(2)}`;

  // Últimos 5 fretes
  const tbody = document.getElementById('dashboard-fretes-tbody');
  const ultimos = todos.slice(0, 8);
  if (ultimos.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-muted" style="text-align:center;padding:24px;">Nenhum frete registrado ainda.</td></tr>';
  } else {
    tbody.innerHTML = ultimos.map(f => `<tr>
      <td><span class="frete-code">${f.code}</span></td>
      <td><strong>${f.freteiro_nome}</strong></td>
      <td><span style="font-size:12px;">${f.origem} → ${f.destino}</span></td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;">R$ ${parseFloat(f.valor).toFixed(2)}</td>
      <td><span class="badge ${statusClass(f.status)}">${statusLabel(f.status)}</span></td>
      <td><span class="badge ${pagClass(f.status_pag)}">${pagLabel(f.status_pag)}</span></td>
    </tr>`).join('');
  }

  // Charts
  buildCharts(todos);
}

function buildCharts(fretes) {
  // Gastos últimos 6 meses
  const meses = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date(); d.setMonth(d.getMonth() - i);
    meses.push(d.toISOString().slice(0,7));
  }
  const gastosPorMes = meses.map(m => fretes.filter(f => f.data?.startsWith(m)).reduce((a,f) => a + (parseFloat(f.valor_pago)||0), 0));

  const ctx1 = document.getElementById('chart-gastos');
  if (chartGastos) chartGastos.destroy();
  chartGastos = new Chart(ctx1, {
    type: 'bar',
    data: {
      labels: meses.map(m => { const [y,mo] = m.split('-'); return `${mo}/${y.slice(2)}`; }),
      datasets: [{ label: 'Total Pago (R$)', data: gastosPorMes, backgroundColor: '#1B3A6B', borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
  });

  // Status
  const statusCount = {
    'Solicitado': fretes.filter(f => f.status==='solicitado').length,
    'Separado':   fretes.filter(f => f.status==='separado').length,
    'Transporte': fretes.filter(f => f.status==='transporte').length,
    'Entregue':   fretes.filter(f => f.status==='entregue').length,
    'Cancelado':  fretes.filter(f => f.status==='cancelado').length,
  };
  const ctx2 = document.getElementById('chart-status');
  if (chartStatus) chartStatus.destroy();
  chartStatus = new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: Object.keys(statusCount),
      datasets: [{ data: Object.values(statusCount), backgroundColor: ['#0284C7','#7C3AED','#D97706','#059669','#DC2626'], borderWidth: 0 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
  });
}

