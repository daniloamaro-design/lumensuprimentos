async function loadPendingCount() {
  const snap = await db.collection(USERS_COL).where('status','==','pending').get();
  const badge = document.getElementById('badge-pending');
  snap.size > 0 ? (badge.textContent = snap.size, badge.classList.remove('hidden')) : badge.classList.add('hidden');
}

async function loadUsers() {
  const snap = await db.collection(USERS_COL).get();
  const pending  = snap.docs.filter(d => d.data().status === 'pending');
  const approved = snap.docs.filter(d => d.data().status !== 'pending');

  const pendEl = document.getElementById('pending-users-list');
  if (pending.length === 0) {
    pendEl.innerHTML = '<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-title">Nenhuma solicitação pendente</div></div>';
  } else {
    pendEl.innerHTML = pending.map(d => {
      const u = d.data();
      return `<div class="pending-card">
        <div><div class="pending-name">${u.name}</div><div class="pending-details">${u.email}</div></div>
        <div style="display:flex;gap:8px;">
          <button class="btn btn-danger btn-sm" onclick="updateUserStatus('${d.id}','rejected')">Recusar</button>
          <button class="btn btn-ok btn-sm" onclick="updateUserStatus('${d.id}','approved')">✓ Aprovar</button>
        </div>
      </div>`;
    }).join('');
  }

  const tbody = document.getElementById('active-users-tbody');
  tbody.innerHTML = approved.map(d => {
    const u = d.data();
    return `<tr>
      <td><strong>${u.name}</strong></td>
      <td>${u.email}</td>
      <td><span class="badge ${u.role==='admin'?'badge-brand':'badge-gray'}">${u.role==='admin'?'Admin':'Usuário'}</span></td>
      <td>${u.email !== ADMIN_EMAIL ? `<button class="btn btn-danger btn-sm" onclick="updateUserStatus('${d.id}','rejected')">Revogar</button>` : '<span class="text-muted text-sm">Admin geral</span>'}</td>
    </tr>`;
  }).join('') || '<tr><td colspan="4" class="text-muted" style="text-align:center;padding:20px;">Nenhum usuário.</td></tr>';
}

async function updateUserStatus(uid, status) {
  await db.collection(USERS_COL).doc(uid).update({ status, updatedAt: firebase.firestore.FieldValue.serverTimestamp() });
  loadUsers(); loadPendingCount();
}

