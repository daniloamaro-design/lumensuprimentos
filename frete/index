document.getElementById('nf-status-pag').addEventListener('change', function() {
  const show = this.value === 'parcial' || this.value === 'pago';
  document.getElementById('nf-valor-pago-group').style.display = show ? 'block' : 'none';
  if (this.value === 'pago') {
    document.getElementById('nf-valor-pago').value = document.getElementById('nf-valor').value;
  }
});

document.getElementById('nf-valor').addEventListener('input', function() {
  if (document.getElementById('nf-status-pag').value === 'pago') {
    document.getElementById('nf-valor-pago').value = this.value;
  }
});

async function salvarFrete() {
  const freteiro_id = v('nf-freteiro');
  const data        = v('nf-data');
  const origem      = v('nf-origem');
  const destino     = v('nf-destino');
  const motivo      = v('nf-motivo');
  const valor       = parseFloat(document.getElementById('nf-valor').value) || 0;

  if (!freteiro_id) { showToast('Selecione o freteiro!'); return; }
  if (!data)        { showToast('Informe a data!'); return; }
  if (!origem)      { showToast('Informe a origem!'); return; }
  if (!destino)     { showToast('Informe o destino!'); return; }
  if (!motivo)      { showToast('Informe o motivo!'); return; }
  if (valor <= 0)   { showToast('Informe o valor!'); return; }

  setBtnLoading('btn-salvar-frete', true);

  const statusPag   = v('nf-status-pag');
  let valorPago = 0;
  if (statusPag === 'pago')    valorPago = valor;
  if (statusPag === 'parcial') valorPago = parseFloat(document.getElementById('nf-valor-pago').value) || 0;

  // Gera código do frete
  const dateStr = data.replace(/-/g,'');
  const snap = await db.collection(FRETES_COL).where('dateStr','==',dateStr).get();
  const seq = String(snap.size + 1).padStart(3,'0');
  const code = `LF-${dateStr}-${seq}`;

  const freteData = {
    code, dateStr, data, freteiro_id,
    freteiro_nome: freteirosCache[freteiro_id]?.nome || '—',
    origem, destino, motivo,
    valor, valor_pago: valorPago,
    status: 'solicitado',
    status_pag: statusPag,
    forma_pag: v('nf-forma-pag'),
    obs: v('nf-obs'),
    createdBy:   currentUserData.name,
    createdByUid: currentUser.uid,
    createdAt: firebase.firestore.FieldValue.serverTimestamp(),
    historico: [{
      acao: 'Frete criado',
      status: 'solicitado',
      status_pag: statusPag,
      valor_pago: valorPago,
      por: currentUserData.name,
      data: new Date().toISOString()
    }]
  };

  try {
    await db.collection(FRETES_COL).add(freteData);
    clearNovoFrete();
    showToast(`✅ Frete ${code} registrado!`);
    if (currentUserData.role === 'admin') { goPage('all-fretes'); }
    else { goPage('meus-fretes'); }
  } catch(e) {
    showToast('Erro: ' + e.message);
    console.error(e);
  }
  setBtnLoading('btn-salvar-frete', false);
}

function clearNovoFrete() {
  ['nf-freteiro','nf-origem','nf-destino','nf-motivo','nf-obs'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('nf-valor').value = '';
  document.getElementById('nf-valor-pago').value = '';
  document.getElementById('nf-data').value = new Date().toISOString().slice(0,10);
  document.getElementById('nf-status-pag').value = 'pendente';
  document.getElementById('nf-forma-pag').value = 'pix';
  document.getElementById('nf-valor-pago-group').style.display = 'none';
}

async function loadAllFretes() {
  const tbody = document.getElementById('all-fretes-tbody');
  tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:24px;"><div class="loading-state"><div class="spinner spinner-dark"></div></div></td></tr>';

  let query = db.collection(FRETES_COL).orderBy('createdAt','desc');
  const filterFreteiro = v('filter-freteiro');
  const filterStatus   = v('filter-status');
  const filterPag      = v('filter-pag');
  const filterMes      = v('filter-mes');

  if (filterFreteiro) query = query.where('freteiro_id','==',filterFreteiro);

  let docs = (await query.get()).docs;
  if (filterStatus) docs = docs.filter(d => d.data().status === filterStatus);
  if (filterPag)    docs = docs.filter(d => d.data().status_pag === filterPag);
  if (filterMes)    docs = docs.filter(d => d.data().data?.startsWith(filterMes));

  if (docs.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" class="text-muted" style="text-align:center;padding:32px;">Nenhum frete encontrado.</td></tr>';
    return;
  }

  tbody.innerHTML = docs.map(d => {
    const f = d.data();
    const restante = (parseFloat(f.valor)||0) - (parseFloat(f.valor_pago)||0);
    return `<tr>
      <td><span class="frete-code">${f.code}</span></td>
      <td class="text-muted text-sm">${f.data || '—'}</td>
      <td><strong>${f.freteiro_nome}</strong></td>
      <td>
        <div class="rota-box" style="padding:4px 8px;font-size:12px;">
          <span style="font-weight:600;">${f.origem}</span>
          <span style="color:var(--muted);margin:0 4px;">→</span>
          <span style="font-weight:600;">${f.destino}</span>
        </div>
      </td>
      <td style="font-size:12px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${f.motivo}">${f.motivo}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;">R$ ${parseFloat(f.valor).toFixed(2)}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;color:var(--ok);">R$ ${parseFloat(f.valor_pago||0).toFixed(2)}</td>
      <td><span class="badge ${statusClass(f.status)}">${statusLabel(f.status)}</span></td>
      <td><span class="badge ${pagClass(f.status_pag)}">${pagLabel(f.status_pag)}</span></td>
      <td style="display:flex;gap:5px;">
        <button class="btn btn-secondary btn-xs" onclick="showFreteDetail('${d.id}')">Ver</button>
        <button class="btn btn-outline btn-xs" onclick="openUpdateStatus('${d.id}')">Atualizar</button>
      </td>
    </tr>`;
  }).join('');
}

