async function loadFinanceiro() {
  const tbody    = document.getElementById('fin-tbody');
  const mes      = v('fin-mes');
  const freteiro = v('fin-freteiro');

  tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:24px;"><div class="loading-state"><div class="spinner spinner-dark"></div></div></td></tr>';

  let query = db.collection(FRETES_COL).orderBy('data','desc');
  if (freteiro) query = query.where('freteiro_id','==',freteiro);

  let docs = (await query.get()).docs;
  if (mes) docs = docs.filter(d => d.data().data?.startsWith(mes));
  docs = docs.filter(d => d.data().status !== 'cancelado');

  const fretes = docs.map(d => ({ id: d.id, ...d.data() }));

  let totalPago = 0, totalPendente = 0, totalParcialRestante = 0, totalGeral = 0;
  fretes.forEach(f => {
    const val = parseFloat(f.valor)||0;
    const pago = parseFloat(f.valor_pago)||0;
    totalGeral += val;
    totalPago  += pago;
    if (f.status_pag === 'pendente') totalPendente += val;
    if (f.status_pag === 'parcial')  totalParcialRestante += (val - pago);
  });

  document.getElementById('fin-pago').textContent     = `R$ ${totalPago.toFixed(2)}`;
  document.getElementById('fin-pendente').textContent = `R$ ${totalPendente.toFixed(2)}`;
  document.getElementById('fin-parcial').textContent  = `R$ ${totalParcialRestante.toFixed(2)}`;
  document.getElementById('fin-total').textContent    = `R$ ${totalGeral.toFixed(2)}`;

  window._finFretes = fretes;

  if (fretes.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" class="text-muted" style="text-align:center;padding:32px;">Nenhum frete encontrado.</td></tr>';
    return;
  }

  tbody.innerHTML = fretes.map(f => {
    const val = parseFloat(f.valor)||0;
    const pago = parseFloat(f.valor_pago)||0;
    const restante = val - pago;
    return `<tr>
      <td><span class="frete-code">${f.code}</span></td>
      <td class="text-muted text-sm">${f.data||'—'}</td>
      <td><strong>${f.freteiro_nome}</strong></td>
      <td style="font-size:12px;">${f.origem} → ${f.destino}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;">R$ ${val.toFixed(2)}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;color:var(--ok);">R$ ${pago.toFixed(2)}</td>
      <td style="font-family:'JetBrains Mono';font-size:12px;font-weight:600;color:${restante>0?'var(--danger)':'var(--ok)'};">R$ ${restante.toFixed(2)}</td>
      <td>${formaPagLabel(f.forma_pag)}</td>
      <td><span class="badge ${pagClass(f.status_pag)}">${pagLabel(f.status_pag)}</span></td>
      <td style="display:flex;gap:5px;">
        <button class="btn btn-secondary btn-xs" onclick="showFreteDetail('${f.id}')">Ver</button>
        <button class="btn btn-outline btn-xs" onclick="openUpdateStatus('${f.id}')">Pagar</button>
      </td>
    </tr>`;
  }).join('');
}

function exportFinanceiroCSV() {
  const fretes = window._finFretes;
  if (!fretes?.length) { showToast('Carregue o financeiro primeiro!'); return; }
  const header = 'Código,Data,Freteiro,Origem,Destino,Valor Total,Valor Pago,Restante,Forma Pgto,Status\n';
  const rows = fretes.map(f => {
    const val = parseFloat(f.valor)||0;
    const pago = parseFloat(f.valor_pago)||0;
    return `"${f.code}","${f.data}","${f.freteiro_nome}","${f.origem}","${f.destino}",${val.toFixed(2)},${pago.toFixed(2)},${(val-pago).toFixed(2)},"${formaPagLabel(f.forma_pag)}","${pagLabel(f.status_pag)}"`;
  }).join('\n');
  const blob = new Blob([header+rows], { type:'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = `LF-Financeiro-${new Date().toISOString().slice(0,10)}.csv`;
  a.click(); URL.revokeObjectURL(url);
}

function gerarRelatorioFinanceiroPDF() {
  const fretes = window._finFretes;
