let currentUser     = null;
let currentUserData = null;
let freteDetalhe    = null;
let freteirosCache  = {};
let chartGastos     = null;
let chartStatus     = null;

// ─────────────────────────────────────────────
// 🔑  AUTH
// ─────────────────────────────────────────────
auth.onAuthStateChanged(async (user) => {
  if (!user) { showAuthScreen('login'); return; }
  currentUser = user;
  try {
    const snap = await db.collection(USERS_COL).doc(user.uid).get();
    if (!snap.exists) { showAuthScreen('pending'); return; }
    currentUserData = snap.data();
    if (currentUserData.status === 'pending')  { showAuthScreen('pending'); return; }
    if (currentUserData.status === 'rejected') {
      auth.signOut();
      showAuthScreen('login');
      showAlert('login-alert', 'Sua solicitação foi recusada.', 'danger');
      return;
    }
    showApp();
  } catch(e) { console.error(e); auth.signOut(); }
});

function showForm(name) {
  ['login','register','pending'].forEach(f => {
    document.getElementById(`form-${f}`).classList.toggle('hidden', f !== name);
  });
}
function showAuthScreen(form) {
  document.getElementById('auth-screen').style.display = 'flex';
  document.getElementById('app-screen').style.display  = 'none';
  showForm(form);
}

async function doLogin() {
  const email = v('login-email'), password = v('login-password');
  if (!email || !password) { showAlert('login-alert','Preencha e-mail e senha.','danger'); return; }
  setBtnLoading('btn-login', true);
  hideAlert('login-alert');
  try {
    await auth.signInWithEmailAndPassword(email, password);
  } catch(e) {
    showAlert('login-alert', friendlyError(e.code), 'danger');
    setBtnLoading('btn-login', false);
  }
}

async function doRegister() {
  const name = v('reg-name'), email = v('reg-email'), password = v('reg-password');
  if (!name || !email || !password) { showAlert('register-alert','Preencha todos os campos.','danger'); return; }
  if (password.length < 6) { showAlert('register-alert','Senha com mínimo 6 caracteres.','danger'); return; }
  setBtnLoading('btn-register', true);
  try {
    const cred = await auth.createUserWithEmailAndPassword(email, password);
    await db.collection(USERS_COL).doc(cred.user.uid).set({
      name, email,
      role:   email === ADMIN_EMAIL ? 'admin' : 'user',
      status: email === ADMIN_EMAIL ? 'approved' : 'pending',
      createdAt: firebase.firestore.FieldValue.serverTimestamp()
    });
    showAlert('register-alert','Solicitação enviada! Aguarde aprovação.','success');
  } catch(e) {
    showAlert('register-alert', friendlyError(e.code), 'danger');
  }
  setBtnLoading('btn-register', false);
}

function friendlyError(code) {
  const m = {
    'auth/user-not-found': 'E-mail não encontrado.',
    'auth/wrong-password': 'Senha incorreta.',
    'auth/invalid-email':  'E-mail inválido.',
    'auth/email-already-in-use': 'E-mail já em uso.',
    'auth/too-many-requests': 'Muitas tentativas. Tente em alguns minutos.',
    'auth/invalid-credential': 'E-mail ou senha incorretos.',
  };
  return m[code] || 'Erro: ' + code;
}

// ─────────────────────────────────────────────
// 🏛️  APP SETUP
// ─────────────────────────────────────────────
async function showApp() {
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app-screen').style.display  = 'block';

  const isAdmin = currentUserData.role === 'admin';
  document.getElementById('topbar-user').textContent = currentUserData.name;
  document.getElementById('sidebar-admin').style.display = isAdmin ? 'block' : 'none';

  // Carrega freteiros no cache
  await loadFreteirosCache();
  populateFreteirosSelects();

  // Set data default
  document.getElementById('nf-data').value = new Date().toISOString().slice(0,10);
  document.getElementById('filter-mes').value = new Date().toISOString().slice(0,7);
  document.getElementById('fin-mes').value = new Date().toISOString().slice(0,7);

  if (isAdmin) {
    goPage('dashboard');
    loadPendingCount();
  } else {
    goPage('novo-frete');
  }
}

// ─────────────────────────────────────────────
// 📄  NAVIGATION
// ─────────────────────────────────────────────
function goPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
  const el = document.getElementById(`page-${page}`);
  if (!el) return;
  el.classList.add('active');
  const btn = document.querySelector(`.sidebar-item[data-page="${page}"]`);
  if (btn) btn.classList.add('active');

  const titles = {
    'dashboard':'Painel Geral','users':'Usuários','all-fretes':'Todos os Fretes',
    'financeiro':'Financeiro','novo-frete':'Novo Frete','meus-fretes':'Meus Fretes',
    'freteiros':'Freteiros'
  };
  document.getElementById('topbar-title').textContent = titles[page] || '';

  if (page === 'dashboard')   loadDashboard();
  if (page === 'users')       loadUsers();
  if (page === 'all-fretes')  loadAllFretes();
  if (page === 'financeiro')  loadFinanceiro();
  if (page === 'meus-fretes') loadMeusFretes();
  if (page === 'freteiros')   loadFreteiros();
}

