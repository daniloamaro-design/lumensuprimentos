    doc.setTextColor(5,150,105);
    doc.text(`R$${pago.toFixed(2)}`, 140, y);
    doc.setTextColor(restante>0?220:5, restante>0?38:150, restante>0?38:105);
    doc.text(`R$${restante.toFixed(2)}`, 158, y);
