function openUpdateStatus(docId) {
  document.getElementById('us-frete-id').value = docId;
  document.getElementById('us-status').value   = 'solicitado';
  document.getElementById('us-pag-status').value = 'pendente';
  document.getElementById('us-valor-pago').value = '';
  document.getElementById('us-obs').value        = '';
  document.getElementById('us-valor-pago-group').style.display = 'none';
  // Carrega valores atuais
  db.collection(FRETES_COL).doc(docId).get().then(snap => {
    if (!snap.exists) return;
    const f = snap.data();
    document.getElementById('us-status').value     = f.status || 'solicitado';
    document.getElementById('us-pag-status').value = f.status_pag || 'pendente';
    document.getElementById('us-forma-pag').value  = f.forma_pag || 'pix';
    document.getElementById('us-valor-pago').value = f.valor_pago || '';
    toggleValorPagoModal();
  });
  openModal('modal-update-status');
}

function toggleValorPagoModal() {
  const s = document.getElementById('us-pag-status').value;
  document.getElementById('us-valor-pago-group').style.display = (s==='parcial'||s==='pago') ? 'block' : 'none';
}

async function salvarUpdateStatus() {
  const docId      = document.getElementById('us-frete-id').value;
  const status     = v('us-status');
  const statusPag  = v('us-pag-status');
  const formaPag   = v('us-forma-pag');
  const obs        = v('us-obs');

  setBtnLoading('btn-save-status', true);

  const snap = await db.collection(FRETES_COL).doc(docId).get();
  const f = snap.data();

  let valorPago = parseFloat(f.valor_pago) || 0;
  if (statusPag === 'pago')    valorPago = parseFloat(f.valor) || 0;
  if (statusPag === 'parcial') valorPago = parseFloat(document.getElementById('us-valor-pago').value) || valorPago;
  if (statusPag === 'pendente') valorPago = 0;

  const histEntry = {
    acao:       `Status: ${statusLabel(status)} · Pgto: ${pagLabel(statusPag)}`,
    status, status_pag: statusPag, valor_pago: valorPago,
    por:        currentUserData.name,
    data:       new Date().toISOString(),
    obs
  };

  try {
    await db.collection(FRETES_COL).doc(docId).update({
      status, status_pag: statusPag, valor_pago: valorPago, forma_pag: formaPag,
      updatedAt: firebase.firestore.FieldValue.serverTimestamp(),
      historico: firebase.firestore.FieldValue.arrayUnion(histEntry)
    });
    showToast('✅ Frete atualizado!');
    closeModal('modal-update-status');
    loadAllFretes();
    loadDashboard();
  } catch(e) {
    showToast('Erro: ' + e.message);
  }
  setBtnLoading('btn-save-status', false);
}

