  if (!valorEl.value || parseFloat(valorEl.value) === 0) {
    // Don't auto-fill — just hint
  }
}

async function handleComprovante(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (file.size > 3*1024*1024) { toast('Arquivo muito grande (máx. 3MB)','error'); return; }
  if (file.type === 'application/pdf') {
    // Store as base64 but can't preview
    const reader = new FileReader();
    reader.onload = e => {
      pagComprovanteBase64 = e.target.result;
      document.getElementById('pag-comp-preview').style.display = 'none';
      const nameEl = document.getElementById('pag-pdf-name');
      if (nameEl) { nameEl.style.display='block'; nameEl.textContent = '📄 ' + file.name; }
      toast('PDF anexado: ' + file.name,'success');
    };
    reader.readAsDataURL(file);
  } else {
    // Image — compress
    const compressed = await compressImage(file, 1000, 0.8);
    pagComprovanteBase64 = compressed;
    const preview = document.getElementById('pag-comp-preview');
    preview.src = compressed;
    preview.style.display = 'block';
    const nameEl = document.getElementById('pag-pdf-name');
    if (nameEl) nameEl.style.display = 'none';
  }
}

async function confirmPagamento() {
  const forn  = document.getElementById('pag-fornecedor').value;
  const data  = document.getElementById('pag-data').value;
  const valor = parseFloat(document.getElementById('pag-valor').value);
  const obs   = document.getElementById('pag-obs').value.trim();
  if (!forn || !data || !valor || valor <= 0) { toast('Preencha fornecedor, data e valor.','error'); return;  }

  // Collect selected passagens
  const checkedIds = [...document.querySelectorAll('input[name="pag-pass"]:checked')].map(cb=>cb.value);
  const passagensSel = checkedIds.map(id => {
    const s = allSolicitacoes.find(x=>x.id===id);
    return s ? { id:s.id, codigo:s.codigo||'—', passageiro:s.passageiro, valor:s.valorFinal } : null;
  }).filter(Boolean);

  const docData = {
    fornecedor: forn,
    data,
    valor,
    obs,
    passagens: passagensSel,
    comprovante: pagComprovanteBase64 || null,
    registradoPor: currentUser.name,
    registradoEm: firebase.firestore.FieldValue.serverTimestamp()
  };

  try {
    const ref = await db.collection('passagens_pagamentos').add(docData);
    allPagamentos.unshift({ id: ref.id, ...docData, registradoEm: new Date() });
    toast(`Pagamento de ${fmtBRL(valor)} para ${forn} registrado! Limite liberado.`,'success');
    closeModal('modal-pagamento');
    // Refresh relevant pages
    const active = document.querySelector('.page.active');
    if (active) refreshPage(active.id.replace('page-',''));
  } catch(e) { toast('Erro ao salvar pagamento.','error'); console.error(e); }
}

function renderPagamentos() {
  // Populate fornecedor filter
  const sel = document.getElementById('pag-filter-forn');
  if (sel) {
    const cur = sel.value;
    const nomes = [...new Set(allPagamentos.map(p=>p.fornecedor))].sort();
    sel.innerHTML = '<option value="">Todos os fornecedores</option>' + nomes.map(n=>`<option value="${n}" ${n===cur?'selected':''}>${esc(n)}</option>`).join('');
  }
  const filtForn = sel ? sel.value : '';

  // Resumo por fornecedor
  const resumo = document.getElementById('pagamentos-resumo');
  if (resumo) {
    resumo.innerHTML = allFornecedores.filter(f=>{
      const gasto = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.fornecedor===f.nome&&s.valorFinal).reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
      return gasto > 0 || allPagamentos.some(p=>p.fornecedor===f.nome);
    }).map(f => {
      const gasto  = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.fornecedor===f.nome&&s.valorFinal).reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
      const pago   = allPagamentos.filter(p=>p.fornecedor===f.nome).reduce((a,p)=>a+(parseFloat(p.valor)||0),0);
      const saldo  = Math.max(0, gasto - pago);
      const disp   = f.limite ? Math.max(0, f.limite - saldo) : null;
      const pct    = f.limite && f.limite > 0 ? Math.min(100,(saldo/f.limite)*100) : null;
      const cor    = pct === null ? 'var(--lumen)' : pct >= 100 ? 'var(--danger)' : pct >= 50 ? 'var(--warn)' : 'var(--ok)';
      return `<div class="card" style="margin-bottom:12px">
        <div class="card-body" style="padding:14px 18px">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
            <div>
              <div style="font-size:15px;font-weight:700">${esc(f.nome)}</div>
              <div style="font-size:12px;color:var(--text-muted);margin-top:2px">
                Total comprado: <strong>${fmtBRL(gasto)}</strong> · Total pago: <strong style="color:var(--ok)">${fmtBRL(pago)}</strong> · 
                Saldo devedor: <strong style="color:${cor}">${fmtBRL(saldo)}</strong>
                ${disp !== null ? ` · Disponível: <strong style="color:var(--ok)">${fmtBRL(disp)}</strong>` : ''}
              </div>
              ${pct !== null ? `<div style="margin-top:6px;height:6px;background:var(--border);border-radius:4px;overflow:hidden;max-width:300px"><div style="height:100%;width:${pct.toFixed(1)}%;background:${cor};border-radius:4px"></div></div>` : ''}
            </div>
            <button class="btn btn-ok btn-sm" onclick="openPagamentoModal('${esc(f.nome)}')">💳 Registrar Pagamento</button>
          </div>
        </div>
      </div>`;
    }).join('') || '<div style="color:var(--text-muted);text-align:center;padding:24px">Nenhuma movimentação financeira ainda.</div>';
  }

  // Histórico table
  let list = allPagamentos;
  if (filtForn) list = list.filter(p=>p.fornecedor===filtForn);

  document.getElementById('pagamentos-tbody').innerHTML = list.length
    ? list.map(p=>{
        const passStr = (p.passagens||[]).length
          ? (p.passagens||[]).map(x=>`<span class="ticket-code" style="font-size:10px">${esc(x.codigo)}</span>`).join(' ')
          : '<span style="color:var(--text-muted);font-size:11px">—</span>';
        const compBtnHtml = p.comprovante
          ? `<button class="btn btn-secondary btn-sm" onclick="viewComprovante('${p.id}')">👁 Ver</button>`
          : '<span style="color:var(--text-muted);font-size:11px">Não anexado</span>';
        return `<tr>
          <td><strong>${fmtDate(p.data)}</strong></td>
          <td>${esc(p.fornecedor)}</td>
          <td><strong style="color:var(--ok)">${fmtBRL(p.valor)}</strong></td>
          <td>${passStr}</td>
          <td style="max-width:180px;font-size:12px">${esc(p.obs||'—')}</td>
          <td>${compBtnHtml}</td>
          <td style="font-size:12px">${esc(p.registradoPor||'—')}</td>
          <td><button class="btn btn-danger btn-sm" onclick="deletePagamento('${p.id}')">🗑️</button></td>
        </tr>`;
      }).join('')
    : '<tr><td colspan="8" style="text-align:center;padding:32px;color:var(--text-muted)">Nenhum pagamento registrado</td></tr>';
}

function viewComprovante(pagId) {
  const p = allPagamentos.find(x=>x.id===pagId);
  if (!p || !p.comprovante) { toast('Nenhum comprovante anexado.','warn'); return; }
  const img = document.getElementById('comprovante-img');
  const nosrc = document.getElementById('comprovante-nosrc');
  img.style.display = 'none';
  if (nosrc) nosrc.style.display = 'none';
  if (p.comprovante.startsWith('data:image')) {
    img.src = p.comprovante;
    img.style.display = 'block';
  } else {
    // PDF or unknown
    if (nosrc) { nosrc.style.display='block'; nosrc.textContent = 'Comprovante em formato não visualizável. Use o download.'; }
  }
  openModal('modal-comprovante');
}

async function deletePagamento(id) {
  if (!confirm('Excluir este pagamento? O saldo devedor será recalculado.')) return;
  try {
    await db.collection('passagens_pagamentos').doc(id).delete();
    allPagamentos = allPagamentos.filter(p=>p.id!==id);
    toast('Pagamento excluído.','warn');
    renderPagamentos();
    renderFornecedores();
  } catch(e) { toast('Erro ao excluir.','error'); console.error(e); }
}

function exportPagamentosPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation:'landscape' });
  doc.setFontSize(14); doc.setTextColor(0,56,117);
  doc.text('Lumen Passagens — Pagamentos aos Fornecedores', 14, 16);
  doc.setFontSize(9); doc.setTextColor(100);
  doc.text(`Gerado em ${new Date().toLocaleString('pt-BR')}`, 14, 22);
  const total = allPagamentos.reduce((a,p)=>a+(parseFloat(p.valor)||0),0);
  doc.autoTable({
    startY:28,
    head:[['Data','Fornecedor','Valor Pago','Passagens Quitadas','Obs','Registrado por']],
    body: allPagamentos.map(p=>[fmtDate(p.data),p.fornecedor,fmtBRL(p.valor),(p.passagens||[]).map(x=>x.codigo).join(', ')||'—',p.obs||'—',p.registradoPor||'—']),
    foot:[['','','Total: '+fmtBRL(total),'','','']],
    headStyles:{fillColor:[0,56,117]}, footStyles:{fillColor:[26,122,68],textColor:255,fontStyle:'bold'}, styles:{fontSize:9}
  });
  doc.save('lumen-pagamentos.pdf');
}

function exportPagamentosExcel() {
  const rows = allPagamentos.map(p=>({
    Data: p.data, Fornecedor: p.fornecedor, 'Valor Pago (R$)': parseFloat(p.valor)||0,
    'Passagens Quitadas': (p.passagens||[]).map(x=>x.codigo).join(', '),
    Observação: p.obs||'', 'Registrado por': p.registradoPor||''
  }));
  const ws = XLSX.utils.json_to_sheet(rows);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Pagamentos');
  XLSX.writeFile(wb, 'lumen-pagamentos.xlsx');
}

// ─── HELPERS ─────────────────────────────────────────────────────
function fmtBRL(v) { return Number(v).toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }
function fmtDate(d) { if(!d) return '—'; const [y,m,dy]=d.split('-'); return `${dy}/${m}/${y}`; }
function fmtDateTime(ts) {
  if (!ts) return '—';
  if (typeof ts === 'string') return new Date(ts).toLocaleString('pt-BR');
  if (ts.toDate) return ts.toDate().toLocaleString('pt-BR');
  return '—';
}
function fmtHistoryDate(ts) {
  if (!ts) return '—';
  if (typeof ts === 'string') return new Date(ts).toLocaleString('pt-BR');
  return '—';
}
function esc(s) { if (!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function gerarCodigo() { return 'PAS-' + Date.now().toString(36).toUpperCase().slice(-6); }
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// Close modal clicking overlay
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('open'); });
});
</script>
