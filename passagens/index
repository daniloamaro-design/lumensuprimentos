      el.appendChild(o);
    });
    if (cur) el.value = cur;
  });

  document.getElementById('transf-data').value = new Date().toISOString().slice(0,10);

  // Mostra/esconde seção de nova transferência baseado em role
  const isAdmin = currentUserData.role === 'admin';
