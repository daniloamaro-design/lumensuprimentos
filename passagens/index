function exportSolicitacaoPDF(id) {
  const s = allSolicitacoes.find(x=>x.id===id);
  if (!s) return;
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();

  // Header
  doc.setFillColor(0,56,117);
  doc.rect(0,0,210,32,'F');
  doc.setFontSize(16); doc.setTextColor(255,255,255);
  doc.text('Lumen Passagens', 14, 14);
  doc.setFontSize(10);
  doc.text('Comprovante de Passagem', 14, 22);
  doc.setFontSize(9); doc.setTextColor(200,220,255);
  doc.text(`Código: ${s.codigo||'—'}  |  Gerado em ${new Date().toLocaleString('pt-BR')}`, 14, 29);

  doc.setTextColor(30,30,30);
  const rows = [
    ['Passageiro', s.passageiro], ['Solicitante', s.solicitante],
    ['Tipo', s.tipo==='aviao'?'Avião ✈':'Ônibus 🚌'], ['Motivo', s.motivo],
    ['Origem', s.origem], ['Destino', s.destino],
    ['Data de Saída', fmtDate(s.saida)], ['Data de Retorno', s.retorno?fmtDate(s.retorno):'—'],
    ['Turno', s.turno||'—'], ['Bagagem', s.bagagem==='sim'?'Sim':'Não'],
    ['Status', STATUS_LABELS[s.status]],
    ...(s.valorFinal?[['Valor Pago',fmtBRL(s.valorFinal)],['Fornecedor',s.fornecedor||'—'],['Nº Bilhete/Reserva',s.numBilhete||'—'],['Data da Compra',s.dataCompra?fmtDate(s.dataCompra):'—']]:[] ),
    ...(s.obs?[['Observações',s.obs]]:[])
  ];
  doc.autoTable({
    startY:36,
    body: rows,
    styles:{ fontSize:10, cellPadding:4 },
    columnStyles:{ 0:{ fontStyle:'bold', cellWidth:55, fillColor:[240,244,250] } },
    alternateRowStyles:{ fillColor:[248,250,255] }
  });

  // Ticket image
  if (s.ticketImg) {
    let finalY = doc.lastAutoTable.finalY + 10;
    if (finalY + 80 > 280) { doc.addPage(); finalY = 14; }
    doc.setFontSize(11); doc.setTextColor(0,56,117);
    doc.text('Imagem do Bilhete', 14, finalY);
    finalY += 6;
    try {
      const imgData = s.ticketImg;
      const imgProps = doc.getImageProperties(imgData);
      const maxW = 180; const maxH = 120;
      const ratio = Math.min(maxW/imgProps.width, maxH/imgProps.height);
      const w = imgProps.width * ratio;
      const h = imgProps.height * ratio;
      doc.addImage(imgData, 'JPEG', 14, finalY, w, h);
      doc.setDrawColor(200,200,200);
      doc.rect(14, finalY, w, h);
    } catch(e) {
      doc.setFontSize(10); doc.setTextColor(150);
      doc.text('(Imagem não pôde ser renderizada)', 14, finalY + 10);
    }
  }

  doc.save(`passagem-${s.codigo||s.id}.pdf`);
}

// ─── PAGAMENTOS AOS FORNECEDORES ────────────────────────────────────
function openPagamentoModal(fornNome = null) {
  // Reset form
  pagComprovanteBase64 = null;
  document.getElementById('pag-fornecedor').innerHTML = '<option value="">Selecione o fornecedor...</option>' +
    allFornecedores.filter(f=>f.ativo!==false).map(f=>`<option value="${esc(f.nome)}" ${f.nome===fornNome?'selected':''}>${esc(f.nome)}</option>`).join('');
  document.getElementById('pag-data').value = new Date().toISOString().split('T')[0];
  document.getElementById('pag-valor').value = '';
  document.getElementById('pag-obs').value = '';
  document.getElementById('pag-saldo-info').textContent = '';
  document.getElementById('pag-comp-preview').style.display = 'none';
  document.getElementById('pag-comp-preview').src = '';
  document.getElementById('pag-comp-input').value = '';

  if (fornNome) {
    onPagFornChange();
  } else {
    document.getElementById('pag-passagens-wrap').innerHTML = '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:8px">Selecione um fornecedor para ver as passagens pendentes</div>';
  }
  openModal('modal-pagamento');
}

function onPagFornChange() {
  const forn = document.getElementById('pag-fornecedor').value;
  if (!forn) {
    document.getElementById('pag-passagens-wrap').innerHTML = '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:8px">Selecione um fornecedor para ver as passagens pendentes</div>';
    document.getElementById('pag-saldo-info').textContent = '';
    return;
  }
  // Calculate saldo devedor
  const f = allFornecedores.find(x=>x.nome===forn);
  const saldo = calcSaldoDevedor(forn);
  const infoEl = document.getElementById('pag-saldo-info');
  if (f && f.limite) {
    const disp = Math.max(0, f.limite - saldo);
    infoEl.innerHTML = `Saldo devedor: <strong style="color:var(--warn)">${fmtBRL(saldo)}</strong> · Limite: ${fmtBRL(f.limite)} · Disponível: <strong style="color:var(--ok)">${fmtBRL(disp)}</strong>`;
  } else if (saldo > 0) {
    infoEl.innerHTML = `Saldo devedor atual: <strong style="color:var(--warn)">${fmtBRL(saldo)}</strong>`;
  } else {
    infoEl.innerHTML = `Sem saldo devedor neste fornecedor.`;
  }
  onPagValorChange();

  // Listar passagens compradas deste fornecedor que ainda não foram totalmente pagas
  const passagens = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.fornecedor===forn&&s.valorFinal);
  const wrap = document.getElementById('pag-passagens-wrap');
  if (!passagens.length) {
    wrap.innerHTML = '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:8px">Nenhuma passagem comprada neste fornecedor</div>';
    return;
  }
  wrap.innerHTML = passagens.map(s=>`
    <label style="display:flex;align-items:center;gap:8px;padding:6px 4px;border-bottom:1px solid var(--border);cursor:pointer;font-size:12px">
      <input type="checkbox" name="pag-pass" value="${s.id}" style="width:14px;height:14px;flex-shrink:0">
      <span class="ticket-code" style="font-size:11px">${s.codigo||'—'}</span>
      <span style="flex:1">${esc(s.passageiro)} · ${esc(s.origem)} → ${esc(s.destino)} · ${fmtDate(s.saida)}</span>
      <strong style="color:var(--lumen);flex-shrink:0">${fmtBRL(s.valorFinal)}</strong>
    </label>
  `).join('');
}

function onPagValorChange() {
  // Auto-suggest: fill valor with saldo devedor
  const forn = document.getElementById('pag-fornecedor').value;
  if (!forn) return;
  const saldo = calcSaldoDevedor(forn);
