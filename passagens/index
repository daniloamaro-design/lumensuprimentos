async function loadDashboard() {
  try {
    const [usersSnap, ordersSnap, housesSnap] = await Promise.all([
      db.collection('users').get(),
      db.collection('orders').orderBy('createdAt','desc').limit(10).get(),
      db.collection('houses').get()
    ]);
    const pending = usersSnap.docs.filter(d => d.data().status === 'pending').length;
    const approved = usersSnap.docs.filter(d => d.data().status === 'approved').length;
    const now = new Date(); const thisMonth = now.getMonth(); const thisYear = now.getFullYear();
    const monthOrders = ordersSnap.docs.filter(d => {
      const ts = d.data().createdAt?.toDate();
      return ts && ts.getMonth() === thisMonth && ts.getFullYear() === thisYear;
    }).length;
    let totalPeople = 0;
    housesSnap.docs.forEach(d => { totalPeople += (d.data().currentPeople || 0); });

    document.getElementById('s-houses').textContent = CASAS.length;
    document.getElementById('s-people').textContent = totalPeople;
    document.getElementById('s-orders').textContent = monthOrders;
    document.getElementById('s-pending').textContent = pending;

    const tbody = document.getElementById('dashboard-orders-tbody');
    if (ordersSnap.empty) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-muted" style="text-align:center;padding:24px;">Nenhum pedido ainda.</td></tr>';
      return;
    }
    tbody.innerHTML = ordersSnap.docs.map(d => {
      const o = d.data();
      return `<tr>
        <td><span class="order-code">${o.code}</span></td>
        <td>${o.house}</td>
        <td>${formatCats(o.categories)}</td>
        <td>${o.requesterName || '—'}</td>
        <td>${formatDate(o.createdAt)}</td>
        <td><span class="badge badge-ok">Enviado</span></td>
      </tr>`;
    }).join('');
  } catch(e) { console.error(e); }
}

