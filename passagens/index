  snap.docs.forEach(d => { housesData[d.data().name] = { id: d.id, ...d.data() }; });

  el.innerHTML = `<div class="table-wrap"><table>
    <thead><tr><th>Casa / Unidade</th><th>Pessoas Atuais</th><th>Última Atualização</th><th>Histórico</th><th>Salvar</th></tr></thead>
    <tbody>
    ${CASAS.map(casa => {
      const h = housesData[casa] || {};
      return `<tr id="house-row-${encodeHouseId(casa)}">
        <td><strong>${casa}</strong></td>
        <td>
          <div class="people-counter">
            <button class="people-btn" onclick="changePeople('${encodeHouseId(casa)}',-1)">−</button>
            <input class="people-input" type="number" min="0" max="999" value="${h.currentPeople || 0}" id="inp-people-${encodeHouseId(casa)}">
            <button class="people-btn" onclick="changePeople('${encodeHouseId(casa)}',1)">+</button>
          </div>
        </td>
        <td class="text-muted text-sm">${h.updatedAt ? formatDate(h.updatedAt) : '—'}</td>
