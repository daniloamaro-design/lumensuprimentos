async function saveFornecedor() {
  const nome = document.getElementById('forn-nome').value.trim();
  if (!nome) { toast('Informe o nome do fornecedor.','error'); return; }
  const data = {
    nome, tipo: document.getElementById('forn-tipo').value,
    tel:   document.getElementById('forn-tel').value.trim(),
    email: document.getElementById('forn-email').value.trim(),
    pix:   document.getElementById('forn-pix').value.trim(),
    site:  document.getElementById('forn-site').value.trim(),
    prazo: document.getElementById('forn-prazo').value.trim(),
    limite: parseFloat(document.getElementById('forn-limite').value)||0,
    vencimento: document.getElementById('forn-vencimento').value||null,
    obs:   document.getElementById('forn-obs').value.trim(),
    ativo: document.getElementById('forn-ativo').value === 'true',
    atualizadoEm: firebase.firestore.FieldValue.serverTimestamp()
  };
  if (fornecedorEditId) {
    await db.collection('passagens_fornecedores').doc(fornecedorEditId).update(data);
  } else {
    data.criadoEm = firebase.firestore.FieldValue.serverTimestamp();
    await db.collection('passagens_fornecedores').add(data);
  }
  await loadFornecedoresData();
  renderFornecedores();
  closeModal('modal-fornecedor');
  toast(fornecedorEditId ? 'Fornecedor atualizado!':'Fornecedor cadastrado!','success');
}

async function deleteFornecedor(id) {
  if (!confirm('Excluir este fornecedor?')) return;
  await db.collection('passagens_fornecedores').doc(id).delete();
  await loadFornecedoresData();
  renderFornecedores();
  toast('Fornecedor removido.','success');
}

// ─── INDICADORES ──────────────────────────────────────────────────
function clearIndicadoresFilters() {
  ['ind-filter-de','ind-filter-ate'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
  const fs = document.getElementById('ind-filter-fornecedor'); if(fs) fs.value='';
  renderIndicadores();
}

function renderIndicadores() {
  const ano = parseInt(document.getElementById('ind-filter-ano')?.value||new Date().getFullYear());
  const de  = document.getElementById('ind-filter-de')?.value||'';
  const ate = document.getElementById('ind-filter-ate')?.value||'';
  const forn= document.getElementById('ind-filter-fornecedor')?.value||'';

  // Populate fornecedor select
  const fs = document.getElementById('ind-filter-fornecedor');
  if (fs) {
    const curForn = fs.value;
    const fornNames = [...new Set(allSolicitacoes.filter(s=>s.fornecedor).map(s=>s.fornecedor))].sort();
    fs.innerHTML = '<option value="">Todos os fornecedores</option>' + fornNames.map(n=>`<option value="${n}" ${n===curForn?'selected':''}>${esc(n)}</option>`).join('');
  }

  const compradas = allSolicitacoes.filter(s => ['comprada','concluida'].includes(s.status) && s.valorFinal && s.dataCompra);
  let doAno = compradas.filter(s => new Date(s.dataCompra+'T00:00:00').getFullYear() === ano);

  const usingRange = de || ate;
  if (usingRange) {
    doAno = compradas.filter(s => {
      if (de && s.dataCompra < de) return false;
      if (ate && s.dataCompra > ate) return false;
      return true;
    });
  }
  if (forn) doAno = doAno.filter(s => s.fornecedor === forn);

  const total = doAno.reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);

  // KPIs
  const aprovadas = allSolicitacoes.filter(s=>['aprovada','comprada','concluida'].includes(s.status)).length;
  const taxa = allSolicitacoes.length ? (aprovadas/allSolicitacoes.length*100).toFixed(1) : 0;
  const antecs = doAno.map(s=>{
    const compra = new Date(s.dataCompra+'T00:00:00');
    const saida  = new Date(s.saida+'T00:00:00');
    return Math.max(0, Math.ceil((saida-compra)/86400000));
  }).filter(x=>x>=0);
  const avgAntec = antecs.length ? (antecs.reduce((a,b)=>a+b,0)/antecs.length).toFixed(1) : '—';
  const economia = doAno.reduce((acc,s)=>{
    const med = calcMediaHistorica(s.origem, s.destino);
    return acc + (med > 0 ? med - parseFloat(s.valorFinal) : 0);
  },0);

  document.getElementById('ind-kpis').innerHTML = `
    <div class="stat-card"><div class="stat-label">Total Gasto ${ano}</div><div class="stat-value lumen">${fmtBRL(total)}</div><div class="stat-desc">${doAno.length} passagens</div></div>
    <div class="stat-card"><div class="stat-label">Taxa de Aprovação</div><div class="stat-value ok">${taxa}%</div><div class="stat-desc">Aprovadas / Total</div></div>
    <div class="stat-card"><div class="stat-label">Antecedência Média</div><div class="stat-value warn">${avgAntec} dias</div><div class="stat-desc">Antes da viagem</div></div>
    <div class="stat-card"><div class="stat-label">Economia Acumulada</div><div class="stat-value ${economia>=0?'ok':'danger'}">${fmtBRL(Math.abs(economia))}</div><div class="stat-desc">${economia>=0?'Abaixo':'Acima'} da média histórica</div></div>
  `;

  // Por motivo
  const porMotivo = {};
  doAno.forEach(s => { porMotivo[s.motivo]=(porMotivo[s.motivo]||0)+(parseFloat(s.valorFinal)||0); });
  renderChart('chart-motivo','doughnut',Object.keys(porMotivo),[{data:Object.values(porMotivo),backgroundColor:CORES}]);

  // Por fornecedor
  const porForn = {};
  doAno.forEach(s => { if (s.fornecedor) porForn[s.fornecedor]=(porForn[s.fornecedor]||0)+(parseFloat(s.valorFinal)||0); });
  const fornEntries = Object.entries(porForn).sort((a,b)=>b[1]-a[1]).slice(0,8);
  renderChart('chart-fornecedor','bar',fornEntries.map(e=>e[0]),[{label:'Gasto (R$)',data:fornEntries.map(e=>e[1]),backgroundColor:CORES,borderRadius:4}],{indexAxis:'y'});

  // Top trajetos
  const porTrajeto = {};
  doAno.forEach(s=>{const k=`${s.origem} → ${s.destino}`;porTrajeto[k]=(porTrajeto[k]||0)+(parseFloat(s.valorFinal)||0);});
  const trajEntries = Object.entries(porTrajeto).sort((a,b)=>b[1]-a[1]).slice(0,8);
  renderChart('chart-trajetos','bar',trajEntries.map(e=>e[0]),[{label:'Gasto (R$)',data:trajEntries.map(e=>e[1]),backgroundColor:'#1A5EA8',borderRadius:4}],{indexAxis:'y'});

  // Top passageiros
  const porPass = {};
  doAno.forEach(s=>{porPass[s.passageiro]=(porPass[s.passageiro]||0)+(parseFloat(s.valorFinal)||0);});
  const passEntries = Object.entries(porPass).sort((a,b)=>b[1]-a[1]).slice(0,8);
  renderChart('chart-passageiros','bar',passEntries.map(e=>e[0]),[{label:'Gasto (R$)',data:passEntries.map(e=>e[1]),backgroundColor:'#6C3483',borderRadius:4}],{indexAxis:'y'});

  // Antecedência
  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const antecPorMes = Array(12).fill(0);
  const cntPorMes   = Array(12).fill(0);
  doAno.forEach(s=>{
    const m = new Date(s.dataCompra+'T00:00:00').getMonth();
    const d = Math.max(0, Math.ceil((new Date(s.saida+'T00:00:00')-new Date(s.dataCompra+'T00:00:00'))/86400000));
    antecPorMes[m]+=d; cntPorMes[m]++;
  });
  const antecMedia = antecPorMes.map((a,i)=>cntPorMes[i]?+(a/cntPorMes[i]).toFixed(1):0);
  renderChart('chart-antecedencia','line',meses,[{label:'Dias de antecedência',data:antecMedia,borderColor:'#D4890A',backgroundColor:'rgba(212,137,10,0.1)',tension:0.3,fill:true}]);

  // Economia
  const economPorMes = Array(12).fill(0);
  doAno.forEach(s=>{
    const med = calcMediaHistorica(s.origem,s.destino);
    if(med>0) { const m=new Date(s.dataCompra+'T00:00:00').getMonth(); economPorMes[m]+=(med-parseFloat(s.valorFinal)); }
  });
  renderChart('chart-economia','bar',meses,[{label:'Economia (R$)',data:economPorMes,backgroundColor:economPorMes.map(v=>v>=0?'#1A7A44':'#C0392B'),borderRadius:4}]);
}

// ─── CALENDÁRIO ───────────────────────────────────────────────────
function renderCalendario() {
  const monthNames = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  document.getElementById('cal-title').textContent = `${monthNames[calMonth]} ${calYear}`;

  const headers = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  document.getElementById('cal-headers').innerHTML = headers.map(h=>`<div class="cal-day-header">${h}</div>`).join('');

  const first = new Date(calYear, calMonth, 1);
  const last  = new Date(calYear, calMonth+1, 0);
  const today = new Date(); today.setHours(0,0,0,0);

  const doMes = allSolicitacoes.filter(s => {
    if (!s.saida) return false;
    const d = new Date(s.saida+'T00:00:00');
    return d.getFullYear()===calYear && d.getMonth()===calMonth && !['reprovada'].includes(s.status);
  });

  let cells = '';
  for (let i=0; i<first.getDay(); i++) {
    cells += `<div class="cal-cell other-month"></div>`;
  }
  for (let d=1; d<=last.getDate(); d++) {
    const dt   = new Date(calYear, calMonth, d);
    const isToday = dt.getTime()===today.getTime();
    const events  = doMes.filter(s=>new Date(s.saida+'T00:00:00').getDate()===d);
    cells += `<div class="cal-cell ${isToday?'today':''}">
      <div class="cal-date-num">${d}</div>
      ${events.map(e=>`<div class="cal-event ${e.tipo}" onclick="openDetalhes('${e.id}')" title="${esc(e.passageiro)}: ${esc(e.origem)} → ${esc(e.destino)}">${e.tipo==='aviao'?'✈':'🚌'} ${esc(e.passageiro.split(' ')[0])}</div>`).join('')}
    </div>`;
  }
  document.getElementById('cal-body').innerHTML = cells;

  // Table
  const sorted = doMes.sort((a,b)=>a.saida.localeCompare(b.saida));
  document.getElementById('cal-tbody').innerHTML = sorted.length
    ? sorted.map(s=>`<tr>
        <td><strong>${fmtDate(s.saida)}</strong></td>
        <td>${esc(s.passageiro)}</td>
        <td><div class="route-display" style="font-size:12px">${esc(s.origem)}<span class="route-arrow">→</span>${esc(s.destino)}</div></td>
        <td><span class="type-icon type-${s.tipo}">${s.tipo==='aviao'?'✈️':'🚌'}</span></td>
        <td><span class="badge status-${s.status}">${STATUS_LABELS[s.status]}</span></td>
        <td>${s.retorno?fmtDate(s.retorno):'—'}</td>
      </tr>`).join('')
    : '<tr><td colspan="6" style="text-align:center;padding:24px;color:var(--text-muted)">Nenhuma viagem neste mês</td></tr>';
}

function calNav(dir) { calMonth += dir; if (calMonth<0) { calMonth=11; calYear--; } if (calMonth>11) { calMonth=0; calYear++; } renderCalendario(); }

