async function loadStockView() {
  const tbody = document.getElementById('stock-view-tbody');
  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:24px;"><div class="loading-state"><div class="spinner spinner-dark"></div>Carregando...</div></td></tr>';

  const filterHouse = document.getElementById('sv-house').value;
  const filterCat   = document.getElementById('sv-cat').value;

  let query = db.collection('movements');
  if (filterHouse) query = query.where('house','==',filterHouse);
  const snap = await query.get();

  // Aggregate: saldo[house][catKey][prodId] = { entradas, saidas }
  const saldo = {};
  snap.docs.forEach(d => {
    const m = d.data();
    if (!saldo[m.house]) saldo[m.house] = {};
    (m.items || []).forEach(item => {
      if (filterCat && item.catKey !== filterCat) return;
      if (!saldo[m.house][item.catKey]) saldo[m.house][item.catKey] = {};
      if (!saldo[m.house][item.catKey][item.prodId]) {
        saldo[m.house][item.catKey][item.prodId] = { e: 0, s: 0, nome: item.prodNome, unidade: item.unidade };
      }
      if (m.type === 'entrada') saldo[m.house][item.catKey][item.prodId].e += item.qty;
      else saldo[m.house][item.catKey][item.prodId].s += item.qty;
    });
  });

  const rows = [];
  Object.entries(saldo).forEach(([house, cats]) => {
    Object.entries(cats).forEach(([catKey, prods]) => {
      const cat = CATEGORIAS[catKey];
      Object.entries(prods).forEach(([prodId, data]) => {
        const saldoAtual = data.e - data.s;
        rows.push({ house, cat, catKey, prodId, data, saldoAtual });
      });
    });
  });

  if (rows.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" class="text-muted" style="text-align:center;padding:32px;">Nenhuma movimentação registrada ainda.</td></tr>';
    return;
  }

  tbody.innerHTML = rows.map(r => {
    const saldoColor = r.saldoAtual < 0 ? 'color:var(--danger);font-weight:700;' : r.saldoAtual === 0 ? 'color:var(--text-muted);' : 'color:var(--ok);font-weight:700;';
    return `<tr>
      <td>${r.house}</td>
      <td>${r.cat.icon} ${r.cat.nome}</td>
      <td>${r.data.nome}</td>
      <td style="color:var(--ok);">+${r.data.e.toFixed(2)}</td>
      <td style="color:var(--danger);">-${r.data.s.toFixed(2)}</td>
      <td style="${saldoColor}">${r.saldoAtual.toFixed(2)}</td>
      <td class="text-muted">${r.data.unidade}</td>
    </tr>`;
  }).join('');

  // Save for CSV export
  window._stockRows = rows;
}

function exportStockCSV() {
  if (!window._stockRows?.length) { showToast('Carregue o estoque primeiro!'); return; }
  const header = 'Casa,Categoria,Produto,Entradas,Saídas,Saldo Atual,Unidade\n';
  const csv = window._stockRows.map(r =>
    `"${r.house}","${r.cat.nome}","${r.data.nome}",${r.data.e.toFixed(2)},${r.data.s.toFixed(2)},${r.saldoAtual.toFixed(2)},"${r.data.unidade}"`
  ).join('\n');
  const blob = new Blob([header + csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = `LM-Estoque-${new Date().toISOString().slice(0,10)}.csv`;
  a.click(); URL.revokeObjectURL(url);
}

