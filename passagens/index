      document.getElementById('forn-site').value  = f.site||'';
      document.getElementById('forn-prazo').value = f.prazo||'';
      document.getElementById('forn-limite').value = f.limite||'';
      document.getElementById('forn-vencimento').value = f.vencimento||'';
