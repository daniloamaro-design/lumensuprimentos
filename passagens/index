// ─── ORÇAMENTOS ───────────────────────────────────────────────────
async function saveOrcamento(id, idx) {
  const forn  = document.getElementById(`orc-forn-${idx}`).value.trim();
  const valor = parseFloat(document.getElementById(`orc-val-${idx}`).value)||0;
  const prazo = document.getElementById(`orc-prazo-${idx}`).value.trim();
  const obs   = document.getElementById(`orc-obs-${idx}`).value.trim();
  const s = allSolicitacoes.find(x=>x.id===id);
  if (!s) return;
  const orcs = [...((s.orcamentos)||[{},{},{}])];
  while(orcs.length<3) orcs.push({});
  orcs[idx] = { fornecedor:forn, valor, prazo, obs };
  await db.collection('passagens_solicitacoes').doc(id).update({ orcamentos: orcs });
  toast('Orçamento salvo!','success');
}

async function selectOrcamento(id, idx) {
  await db.collection('passagens_solicitacoes').doc(id).update({ orcamentoSelecionado: idx });
  toast('Orçamento selecionado!','success');
  openDetalhes(id);
}

// ─── FINANCEIRO ───────────────────────────────────────────────────
function clearFinanceiroFilters() {
  ['fin-filter-de','fin-filter-ate'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
  const fs = document.getElementById('fin-filter-fornecedor'); if(fs) fs.value='';
  renderFinanceiro();
}

function renderFinanceiro() {
  const ano = parseInt(document.getElementById('fin-filter-ano')?.value||new Date().getFullYear());
  const de  = document.getElementById('fin-filter-de')?.value||'';
  const ate = document.getElementById('fin-filter-ate')?.value||'';
  const forn= document.getElementById('fin-filter-fornecedor')?.value||'';

  // Populate fornecedor select
  const fs = document.getElementById('fin-filter-fornecedor');
  if (fs) {
    const curForn = fs.value;
    const fornNames = [...new Set(allSolicitacoes.filter(s=>s.fornecedor).map(s=>s.fornecedor))].sort();
    fs.innerHTML = '<option value="">Todos os fornecedores</option>' + fornNames.map(n=>`<option value="${n}" ${n===curForn?'selected':''}>${esc(n)}</option>`).join('');
  }

  const compradas = allSolicitacoes.filter(s => ['comprada','concluida'].includes(s.status) && s.valorFinal && s.dataCompra);
  let doAno = compradas.filter(s => new Date(s.dataCompra+'T00:00:00').getFullYear() === ano);

  // Apply date range filter (overrides year if set)
  const usingRange = de || ate;
  if (usingRange) {
    doAno = compradas.filter(s => {
      if (de && s.dataCompra < de) return false;
      if (ate && s.dataCompra > ate) return false;
      return true;
    });
  }
  if (forn) doAno = doAno.filter(s => s.fornecedor === forn);

  const totalAno  = doAno.reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const totalOnibus = doAno.filter(s=>s.tipo==='onibus').reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const totalAviao  = doAno.filter(s=>s.tipo==='aviao').reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const avgTicket   = doAno.length ? totalAno/doAno.length : 0;

  document.getElementById('fin-kpis').innerHTML = `
    <div class="stat-card"><div class="stat-label">Total ${ano}</div><div class="stat-value lumen">${fmtBRL(totalAno)}</div><div class="stat-desc">${doAno.length} passagem(ns)</div></div>
    <div class="stat-card"><div class="stat-label">Ônibus</div><div class="stat-value">${fmtBRL(totalOnibus)}</div><div class="stat-desc">${doAno.filter(s=>s.tipo==='onibus').length} viagens</div></div>
    <div class="stat-card"><div class="stat-label">Avião</div><div class="stat-value">${fmtBRL(totalAviao)}</div><div class="stat-desc">${doAno.filter(s=>s.tipo==='aviao').length} viagens</div></div>
    <div class="stat-card"><div class="stat-label">Ticket Médio</div><div class="stat-value">${fmtBRL(avgTicket)}</div><div class="stat-desc">Por passagem</div></div>
  `;

  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const porMes = Array(12).fill(0);
  doAno.forEach(s => { porMes[new Date(s.dataCompra+'T00:00:00').getMonth()] += parseFloat(s.valorFinal)||0; });
  renderChart('chart-fin-mensal','bar',meses,[{label:'Gasto (R$)',data:porMes,backgroundColor:'#003875',borderRadius:6}]);
  renderChart('chart-fin-tipo','doughnut',['Ônibus','Avião'],[{data:[totalOnibus,totalAviao],backgroundColor:['#1565C0','#2E7D32']}]);

  document.getElementById('fin-tbody').innerHTML = doAno.length
    ? doAno.map(s=>`<tr>
        <td><span class="ticket-code">${s.codigo||'—'}</span></td>
        <td>${esc(s.passageiro)}</td>
        <td><div class="route-display" style="font-size:12px">${esc(s.origem)}<span class="route-arrow">→</span>${esc(s.destino)}</div></td>
        <td><span class="type-icon type-${s.tipo}">${s.tipo==='aviao'?'✈️':'🚌'}</span></td>
        <td><span class="badge badge-info">${s.motivo}</span></td>
        <td>${esc(s.fornecedor||'—')}</td>
        <td><strong style="color:var(--ok)">${fmtBRL(s.valorFinal)}</strong></td>
        <td>${fmtDate(s.dataCompra)}</td>
      </tr>`).join('')
    : '<tr><td colspan="8" style="text-align:center;padding:24px;color:var(--text-muted)">Nenhuma passagem comprada neste período</td></tr>';
}

// ─── FORNECEDORES ─────────────────────────────────────────────────
function calcSaldoDevedor(fornNome) {
  const gasto = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.fornecedor===fornNome&&s.valorFinal).reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const pago  = allPagamentos.filter(p=>p.fornecedor===fornNome).reduce((a,p)=>a+(parseFloat(p.valor)||0),0);
  return Math.max(0, gasto - pago);
}

function renderFornecedores() {
  const list = document.getElementById('fornecedores-list');
  if (!allFornecedores.length) {
    list.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🏢</div><div class="empty-state-title">Nenhum fornecedor cadastrado</div><div>Adicione fornecedores para agilizar o registro de compras.</div></div>';
    return;
  }
  const today = new Date(); today.setHours(0,0,0,0);
  list.innerHTML = allFornecedores.map(f=>{
    // Check vencimento alert
    let vencimentoHtml = '';
    if (f.vencimento) {
      const venc = new Date(f.vencimento+'T00:00:00');
      const diff = Math.ceil((venc - today) / 86400000);
      const vencStr = fmtDate(f.vencimento);
      if (diff < 0) {
        vencimentoHtml = `<div style="margin-top:6px;padding:5px 10px;background:var(--danger-bg);border-radius:6px;font-size:12px;color:var(--danger);font-weight:600">⚠️ Fatura VENCIDA em ${vencStr}</div>`;
      } else if (diff <= 7) {
        vencimentoHtml = `<div style="margin-top:6px;padding:5px 10px;background:var(--warn-bg);border-radius:6px;font-size:12px;color:var(--warn);font-weight:600">⏰ Vence em ${vencStr} (${diff} dia${diff!==1?'s':''})</div>`;
      } else {
        vencimentoHtml = `<div style="margin-top:4px;font-size:12px;color:var(--text-muted)">📅 Vencimento: ${vencStr}</div>`;
      }
    }
    // Rotativo credit (gasto - pago = saldo devedor; limite - saldo = disponível)
    let limiteHtml = '';
    if (f.limite && f.limite > 0) {
      const gasto = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.fornecedor===f.nome&&s.valorFinal).reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
      const pago  = allPagamentos.filter(p=>p.fornecedor===f.nome).reduce((a,p)=>a+(parseFloat(p.valor)||0),0);
      const saldo  = Math.max(0, gasto - pago);
      const disponivel = Math.max(0, f.limite - saldo);
      const pct = Math.min(100, (saldo/f.limite)*100);
      const cor = pct >= 100 ? 'var(--danger)' : pct >= 50 ? 'var(--warn)' : 'var(--ok)';
      const ultPag = allPagamentos.filter(p=>p.fornecedor===f.nome).sort((a,b)=>b.data?.localeCompare(a.data||'')||0)[0];
      limiteHtml = `<div style="margin-top:8px">
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-bottom:3px">
          <span>Saldo devedor: <strong style="color:${cor}">${fmtBRL(saldo)}</strong> de ${fmtBRL(f.limite)} · Disponível: <strong style="color:var(--ok)">${fmtBRL(disponivel)}</strong></span>
          <span style="font-weight:700;color:${cor}">${pct.toFixed(1)}%</span>
        </div>
        <div style="height:6px;background:var(--border);border-radius:4px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${cor};border-radius:4px;transition:width 0.3s"></div>
        </div>
        ${ultPag ? `<div style="font-size:11px;color:var(--text-muted);margin-top:3px">Último pagamento: ${fmtBRL(ultPag.valor)} em ${fmtDate(ultPag.data)}</div>` : ''}
      </div>`;
    }
    return `
    <div class="supplier-card">
      <div style="flex:1">
        <div class="supplier-name">${esc(f.nome)} <span class="badge ${f.ativo!==false?'badge-ok':'badge-gray'}">${f.ativo!==false?'Ativo':'Inativo'}</span></div>
        <div class="supplier-meta">
          <span class="type-icon type-${f.tipo==='ambos'?'onibus':f.tipo}" style="font-size:11px">${f.tipo==='ambos'?'✈️🚌 Ambos':f.tipo==='aviao'?'✈️ Avião':'🚌 Ônibus'}</span>
          ${f.tel?` · 📞 ${esc(f.tel)}`:''}
          ${f.email?` · ✉️ ${esc(f.email)}`:''}
          ${f.prazo?` · 💳 ${esc(f.prazo)}`:''}
        </div>
        ${f.pix?`<div class="supplier-meta">PIX: ${esc(f.pix)}</div>`:''}
        ${f.site?`<div class="supplier-meta"><a href="${f.site}" target="_blank" style="color:var(--lumen)">🌐 ${esc(f.site)}</a></div>`:''}
        ${f.obs?`<div class="supplier-meta" style="font-style:italic">${esc(f.obs)}</div>`:''}
        ${vencimentoHtml}
        ${limiteHtml}
      </div>
      <div class="supplier-actions" style="flex-direction:column;align-items:flex-end;gap:6px">
        <div style="display:flex;gap:6px">
          <button class="btn btn-secondary btn-sm" onclick="openFornecedorModal('${f.id}')">✏️ Editar</button>
          <button class="btn btn-danger btn-sm" onclick="deleteFornecedor('${f.id}')">🗑️</button>
        </div>
        <button class="btn btn-ok btn-sm" style="width:100%" onclick="openPagamentoModal('${esc(f.nome)}')">💳 Registrar Pagamento</button>
      </div>
    </div>`;
  }).join('');
}

