    showPane('login');
    return;
  }
  const snap = await db.collection('users').doc(user.uid).get();
  if (!snap.exists || !snap.data().approved) {
    showPane('pending');
    document.getElementById('auth-screen').style.display = 'flex';
    document.getElementById('app-screen').style.display  = 'none';
    return;
  }
  currentUser = { uid: user.uid, ...snap.data() };
  currentRole = snap.data().role || 'user';
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app-screen').style.display  = 'block';
  document.getElementById('topbar-user').textContent   = currentUser.name;
  applyRoleVisibility();
  await loadFornecedoresData();
  startListener();
  goPage(currentRole === 'admin' ? 'dashboard' : 'nova');
  populateYearFilters();
});

function applyRoleVisibility() {
  document.querySelectorAll('.admin-only').forEach(el => {
    el.style.display = currentRole === 'admin' ? '' : 'none';
  });
}

// ─── FIRESTORE LISTENER ───────────────────────────────────────────
function startListener() {
  if (unsubSolicitacoes) unsubSolicitacoes();
  unsubSolicitacoes = db.collection('passagens_solicitacoes')
    .orderBy('criadoEm', 'desc')
    .onSnapshot(snap => {
      allSolicitacoes = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      updateBadge();
      // Reload pagamentos to keep rotativo credit current
      db.collection('passagens_pagamentos').orderBy('data','desc').get().then(s2 => {
        allPagamentos = s2.docs.map(d=>({id:d.id,...d.data()}));
        const active = document.querySelector('.page.active');
        if (active) {
          const id = active.id.replace('page-','');
          refreshPage(id);
        }
      });
    });
}

async function loadFornecedoresData() {
  const snap = await db.collection('passagens_fornecedores').get();
  allFornecedores = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  const snap2 = await db.collection('passagens_pagamentos').orderBy('data','desc').get();
  allPagamentos = snap2.docs.map(d => ({ id: d.id, ...d.data() }));
}

function updateBadge() {
  const n = allSolicitacoes.filter(s => s.status === 'pendente').length;
  const b = document.getElementById('badge-pendente');
  b.style.display = n > 0 ? '' : 'none';
  b.textContent = n;
}

// ─── NAVIGATION ───────────────────────────────────────────────────
const PAGE_TITLES = {
  dashboard:'Dashboard', gerenciar:'Todas as Solicitações', nova:'Nova Solicitação',
  minhas:'Minhas Solicitações', financeiro:'Controle Financeiro', fornecedores:'Fornecedores',
  pagamentos:'Pagamentos aos Fornecedores',
  indicadores:'Indicadores', calendario:'Calendário de Viagens', usuarios:'Usuários'
};

function goPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
  const pg = document.getElementById('page-'+id);
  if (pg) pg.classList.add('active');
  document.querySelectorAll('.sidebar-item').forEach(b => {
    if (b.getAttribute('onclick') && b.getAttribute('onclick').includes(`'${id}'`)) b.classList.add('active');
  });
  document.getElementById('topbar-title').textContent = PAGE_TITLES[id] || id;
  refreshPage(id);
}

function refreshPage(id) {
  if (id === 'dashboard')    renderDashboard();
  if (id === 'gerenciar')    renderGerenciar();
  if (id === 'minhas')       renderMinhas();
  if (id === 'financeiro')   renderFinanceiro();
  if (id === 'indicadores')  renderIndicadores();
  if (id === 'calendario')   renderCalendario();
  if (id === 'usuarios')     renderUsuarios();
  if (id === 'fornecedores') renderFornecedores();
  if (id === 'pagamentos')  renderPagamentos();
  if (id === 'nova')         initNovaForm();
}

function populateYearFilters() {
  const years = [...new Set(allSolicitacoes.map(s => {
    const d = s.saida ? new Date(s.saida+'T00:00:00') : null;
    return d ? d.getFullYear() : new Date().getFullYear();
  }))];
  const cur = new Date().getFullYear();
  if (!years.includes(cur)) years.push(cur);
  years.sort((a,b)=>b-a);
  ['fin-filter-ano','ind-filter-ano'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const val = el.value || cur;
    el.innerHTML = years.map(y=>`<option value="${y}" ${y==val?'selected':''}>${y}</option>`).join('');
  });
}

// ─── DASHBOARD ────────────────────────────────────────────────────
function renderDashboard() {
  const today = new Date(); today.setHours(0,0,0,0);
  const compradas = allSolicitacoes.filter(s => ['comprada','concluida'].includes(s.status) && s.valorFinal);
  const mes = new Date().getMonth(); const ano = new Date().getFullYear();
  const gastomes = compradas.filter(s => {
    const d = s.dataCompra ? new Date(s.dataCompra+'T00:00:00') : (s.criadoEm ? s.criadoEm.toDate() : null);
    return d && d.getMonth()===mes && d.getFullYear()===ano;
  }).reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const total = compradas.reduce((a,s)=>a+(parseFloat(s.valorFinal)||0),0);
  const aprovadas = allSolicitacoes.filter(s=>['aprovada','comprada','concluida'].includes(s.status)).length;
  const taxa = allSolicitacoes.length ? Math.round(aprovadas/allSolicitacoes.length*100) : 0;

  document.getElementById('kpi-total').textContent  = allSolicitacoes.length;
  document.getElementById('kpi-pendente').textContent = allSolicitacoes.filter(s=>s.status==='pendente').length;
  document.getElementById('kpi-aprovadas').textContent = allSolicitacoes.filter(s=>s.status==='aprovada').length;
  document.getElementById('kpi-mes').textContent = fmtBRL(gastomes);
  document.getElementById('kpi-total-gasto').textContent = fmtBRL(total);
  document.getElementById('kpi-taxa').textContent = taxa+'%';

  // Alertas urgentes
  const alerts = allSolicitacoes.filter(s => {
    if (!['aprovada'].includes(s.status)) return false;
    const saida = new Date(s.saida+'T00:00:00');
    const diff = Math.ceil((saida - today) / 86400000);
    return diff >= 0 && diff <= 7;
  });
  const alertsDiv = document.getElementById('dash-alerts');
  if (alerts.length) {
    alertsDiv.innerHTML = `<div class="alert-banner warn"><div class="alert-banner-icon">⚠️</div><div><div class="alert-banner-title">Atenção: ${alerts.length} viagem(ns) próxima(s) sem passagem comprada!</div><div class="alert-banner-text">${alerts.map(a=>`${a.passageiro} — ${a.origem} → ${a.destino} (${fmtDate(a.saida)})`).join(' | ')}</div></div></div>`;
  } else alertsDiv.innerHTML = '';

  // Alertas de limite de fornecedores (50%+)
  const supplierAlertsDiv = document.getElementById('dash-supplier-alerts');
  if (supplierAlertsDiv) {
    const today2 = new Date(); today2.setHours(0,0,0,0);
    let supplierAlerts = [];
    allFornecedores.forEach(f => {
      if (!f.limite || f.limite <= 0) return;
      const saldo = calcSaldoDevedor(f.nome);
      const pct = (saldo/f.limite)*100;
      if (pct >= 50) {
        supplierAlerts.push({ nome: f.nome, pct: pct.toFixed(1), saldo, limite: f.limite, overLimit: pct >= 100 });
      }
    });
    // Alertas de vencimento
    let vencAlerts = [];
    allFornecedores.forEach(f => {
      if (!f.vencimento) return;
      const venc = new Date(f.vencimento+'T00:00:00');
      const diff = Math.ceil((venc - today2) / 86400000);
      if (diff <= 7) {
        vencAlerts.push({ nome: f.nome, diff, data: fmtDate(f.vencimento), vencido: diff < 0 });
      }
    });
    let html = '';
    if (supplierAlerts.length) {
      html += `<div class="alert-banner warn" style="margin-bottom:8px"><div class="alert-banner-icon">💳</div><div style="flex:1"><div class="alert-banner-title">Limite de Crédito: ${supplierAlerts.length} fornecedor(es) com saldo devedor acima de 50%!</div><div class="alert-banner-text">${supplierAlerts.map(a=>`<strong>${a.nome}</strong>: ${a.pct}% do limite (saldo devedor ${fmtBRL(a.saldo)} de ${fmtBRL(a.limite)})${a.overLimit?' ⛔ LIMITE EXCEDIDO':''}`).join(' · ')}</div></div></div>`;
    }
    if (vencAlerts.length) {
      html += `<div class="alert-banner" style="margin-bottom:8px"><div class="alert-banner-icon">📅</div><div style="flex:1"><div class="alert-banner-title">Vencimento de faturas próximo!</div><div class="alert-banner-text">${vencAlerts.map(a=>a.vencido?`<strong>${a.nome}</strong>: VENCIDA em ${a.data}`:`<strong>${a.nome}</strong>: vence em ${a.data} (${a.diff} dia${a.diff!==1?'s':''})`).join(' · ')}</div></div></div>`;
    }
    supplierAlertsDiv.innerHTML = html;
  }

  // Charts
  const meses = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const gastosPorMes = Array(12).fill(0);
  compradas.forEach(s => {
    const d = s.dataCompra ? new Date(s.dataCompra+'T00:00:00') : (s.criadoEm ? s.criadoEm.toDate() : null);
    if (d && d.getFullYear() === ano) gastosPorMes[d.getMonth()] += parseFloat(s.valorFinal)||0;
  });
  renderChart('chart-gastos-mensais', 'bar', meses, [{ label:'Gasto (R$)', data: gastosPorMes, backgroundColor: '#003875', borderRadius:6 }]);

  const statusCounts = {};
  allSolicitacoes.forEach(s => { statusCounts[s.status] = (statusCounts[s.status]||0)+1; });
  renderChart('chart-status', 'doughnut',
    Object.keys(statusCounts).map(k=>STATUS_LABELS[k]||k),
    [{ data: Object.values(statusCounts), backgroundColor: ['#f0f0f0','#D4890A','#003875','#6C3483','#1A7A44','#C0392B'] }]
  );

  // Recent table
  const recent = allSolicitacoes.slice(0,10);
  document.getElementById('dash-recent-tbody').innerHTML = recent.length
    ? recent.map(s=>`<tr>
        <td><span class="ticket-code">${s.codigo||'—'}</span></td>
        <td>${esc(s.passageiro)}</td>
        <td><div class="route-display">${esc(s.origem)}<span class="route-arrow">→</span>${esc(s.destino)}</div></td>
        <td><span class="type-icon type-${s.tipo}">${s.tipo==='aviao'?'✈️':'🚌'} ${s.tipo==='aviao'?'Avião':'Ônibus'}</span></td>
        <td>${fmtDate(s.saida)}</td>
        <td><span class="badge status-${s.status}">${STATUS_LABELS[s.status]||s.status}</span></td>
      </tr>`).join('')
    : '<tr><td colspan="6" class="empty-state" style="text-align:center;padding:24px;color:var(--text-muted)">Nenhuma solicitação</td></tr>';
}

