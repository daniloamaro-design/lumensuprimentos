function exportFinanceiroExcel() {
  const ano = parseInt(document.getElementById('fin-filter-ano')?.value||new Date().getFullYear());
  const rows = allSolicitacoes.filter(s=>['comprada','concluida'].includes(s.status)&&s.valorFinal&&s.dataCompra&&new Date(s.dataCompra+'T00:00:00').getFullYear()===ano)
    .map(s=>({ Código:s.codigo, Passageiro:s.passageiro, Origem:s.origem, Destino:s.destino, Tipo:s.tipo, Motivo:s.motivo, Fornecedor:s.fornecedor||'', 'Valor (R$)':parseFloat(s.valorFinal), 'Data Compra':s.dataCompra }));
