// ─── STATUS CHANGES ───────────────────────────────────────────────
async function changeStatus(id, newStatus, extra={}) {
  const s = allSolicitacoes.find(x=>x.id===id);
  if (!s) return;
  const update = { status: newStatus, ...extra };
  const entry  = { acao: `Status → ${STATUS_LABELS[newStatus]}`, usuario: currentUser.name, ts: new Date().toISOString() };
  update.historico = firebase.firestore.FieldValue.arrayUnion(entry);
  await db.collection('passagens_solicitacoes').doc(id).update(update);
  toast(`Status atualizado: ${STATUS_LABELS[newStatus]}`, 'success');
  closeModal('modal-detalhes');
}

function openReprovar(id) { reprovarTargetId = id; document.getElementById('reprovar-motivo').value=''; openModal('modal-reprovar'); }
async function confirmReprovar() {
  const motivo = document.getElementById('reprovar-motivo').value.trim();
  if (!motivo) { toast('Informe o motivo.','error'); return; }
  await changeStatus(reprovarTargetId, 'reprovada', { motivoReprovacao: motivo });
  closeModal('modal-reprovar');
}

function openComprar(id) {
  comprarTargetId = id;
  compraImageBase64 = null;
  document.getElementById('compra-preview').style.display = 'none';
  document.getElementById('compra-valor').value = '';
  document.getElementById('compra-data').value  = new Date().toISOString().slice(0,10);
  document.getElementById('compra-bilhete').value = '';
  document.getElementById('compra-obs').value    = '';
  // Populate fornecedores
  const sel = document.getElementById('compra-fornecedor');
  const s   = allSolicitacoes.find(x=>x.id===id);
  const tipo = s?.tipo;
  sel.innerHTML = '<option value="">Selecione...</option>' + allFornecedores
    .filter(f => f.ativo !== false && (!tipo || f.tipo === tipo || f.tipo === 'ambos'))
    .map(f=>`<option value="${f.nome}">${esc(f.nome)} (${f.tipo})</option>`).join('');
  openModal('modal-comprar');
}

async function confirmCompra() {
  const valor     = parseFloat(document.getElementById('compra-valor').value);
  const fornecedor= document.getElementById('compra-fornecedor').value;
  const dataCompra= document.getElementById('compra-data').value;
  if (!valor||valor<=0||!fornecedor||!dataCompra) { toast('Preencha todos os campos obrigatórios.','error'); return; }
  const s = allSolicitacoes.find(x=>x.id===comprarTargetId);
  const update = {
    status: 'comprada', valorFinal: valor, fornecedor, dataCompra,
    numBilhete: document.getElementById('compra-bilhete').value,
    obsCompra: document.getElementById('compra-obs').value,
    ticketImg: compraImageBase64 || null,
    historico: firebase.firestore.FieldValue.arrayUnion({ acao:`Passagem comprada — ${fmtBRL(valor)} via ${fornecedor}`, usuario: currentUser.name, ts: new Date().toISOString() })
  };
  await db.collection('passagens_solicitacoes').doc(comprarTargetId).update(update);
  toast('Compra registrada com sucesso! 🎫','success');

  // Enviar email ao solicitante
  if (s && s.solicitanteEmail) {
    try {
      await sendPurchaseEmail({
        to_email: s.solicitanteEmail,
        to_name: s.solicitante,
        codigo: s.codigo||'—',
        passageiro: s.passageiro,
        origem: s.origem,
        destino: s.destino,
        tipo: s.tipo === 'aviao' ? 'Avião' : 'Ônibus',
        saida: fmtDate(s.saida),
        retorno: s.retorno ? fmtDate(s.retorno) : '—',
        fornecedor: fornecedor,
        valor: fmtBRL(valor),
        dataCompra: fmtDate(dataCompra),
        numBilhete: document.getElementById('compra-bilhete').value || '—'
      });
      toast('E-mail de confirmação enviado ao solicitante! 📧','success');
    } catch(e) {
      console.warn('Erro ao enviar email:', e);
      toast('Compra registrada, mas houve falha no envio do email.','warn');
    }
  }

  closeModal('modal-comprar');
  closeModal('modal-detalhes');
}

async function sendPurchaseEmail(params) {
  // Using EmailJS - initialize with your public key
  // Replace 'YOUR_SERVICE_ID', 'YOUR_TEMPLATE_ID', 'YOUR_PUBLIC_KEY' with actual values
  if (typeof emailjs === 'undefined') { console.warn('EmailJS não carregado'); return; }
  
  const templateParams = {
    to_email: params.to_email,
    to_name: params.to_name,
    codigo: params.codigo,
    passageiro: params.passageiro,
    rota: `${params.origem} → ${params.destino}`,
    tipo: params.tipo,
    data_saida: params.saida,
    data_retorno: params.retorno,
    fornecedor: params.fornecedor,
    valor: params.valor,
    data_compra: params.dataCompra,
    num_bilhete: params.numBilhete,
    comprador: currentUser.name
  };

  // EmailJS send — configure your IDs in the constants below:
  const EMAILJS_SERVICE_ID  = 'service_lumen';   // <-- substitua pelo seu Service ID
  const EMAILJS_TEMPLATE_ID = 'template_lumen';  // <-- substitua pelo seu Template ID
  const EMAILJS_PUBLIC_KEY  = 'YOUR_PUBLIC_KEY'; // <-- substitua pela sua Public Key

  await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams, EMAILJS_PUBLIC_KEY);
}

